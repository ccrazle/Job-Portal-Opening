# ── Supabase Postgres ──
# Get from: Supabase Studio → Connect → Connection string (URI)
DATABASE_URL=postgresql://postgres:<PASSWORD>@<SUPABASE_HOST>:5432/postgres

# Set PGSSL=disable only if connecting over internal network without TLS
# PGSSL=disable

# ── Server ──
PORT=3000
APP_BASE_URL=https://your-domain.com

# ── OpenRouter (AI resume scorer) ──
OPENROUTER_API_KEY=sk-or-v1-...
